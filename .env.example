# Lead Stampede MCP Server — Environment Variables
# Copy this file to .env and fill in the values

# ----- Supabase -----
# Your Supabase project URL — find it at: Project Settings → API → Project URL
SUPABASE_URL=https://xlhxnlhxeprtzwbyepza.supabase.co

# service_role key (NEVER the anon key) — find at: Project Settings → API → service_role secret
# This key bypasses RLS. Guard it like a password. Never commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- Server -----
PORT=3000
NODE_ENV=development
